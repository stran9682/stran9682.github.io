---
import "../styles/global.css"
---

<div class="container">
	<div class="intro">
		<div class="text">
			<h1 class="titles">ABOUT ME</h1>

			<h2 class="space-mono-regular">Graduate Assistant at West Chester University</h2>
		</div>

		<img src="nyc-trip.webp" alt="Me at the Brookyln Bridge.">
	</div>

	<div>
		<h2 class="titles">EDUCATION</h2>
		<ul class="space-mono-regular">
			<li>
				Accelerated M.S. + B.S. Computer Science, Minor in Applied Statistics <br/>
				@ West Chester University, 2023-2026  <br/>
				Graudated Summa Cum Laude
			</li>

			<li>
				M.S. Computer Science <br/>
				@ West Chester University, 2025-2027
			</li>
		</ul>
	</div>
</div>

<style>
	.intro {
		display: flex;
		flex-direction: row;
		padding-bottom: 1em;
		gap: 1em;
	}

	.intro .text {
		display: flex;
		flex-direction: column;
		justify-content: center;

	}

	.titles {
		font-family: "Bodoni Moda", serif;
		font-optical-sizing: auto;
		font-weight: 600;
		font-style: normal;
		line-height: 1;
	}

	.container {
		background-color: #14191B;
		background-image: url("/floral.svg");
		background-blend-mode: multiply; 
		background-size: cover;
		padding: 1.2em;
		white-space: normal;
		display: flex;
    	flex-direction: column;
		box-sizing: border-box;
	}

	h1 {
		margin: 0;
		font-size: 3em;
		line-height: 0.8;		
	}

	h2 {
		margin: 0;
		font-size: 1.5em;
	}

	ul {
		padding: 0;
		margin: 0;
		list-style-type: none;
	}

	img {
		width: 50%;
		height: 17em;
		object-fit: cover;
	}

	li {
		border-top: 3px solid white;
		padding-top: 0.3em;
		padding-bottom: 1em;
	}

</style>
